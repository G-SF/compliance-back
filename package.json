{
  "name": "backend-api",
  "version": "1.0.0",
  "description": "Production-ready Node.js TypeScript backend API with auth, MongoDB, and Redis",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "dev:stripe": "concurrently --names \"API,STRIPE\" --prefix-colors \"cyan,yellow\" \"npm run dev\" \"npm run stripe:listen\"",
    "stripe:listen": "C:\\Users\\gabri\\.stripe\\stripe.exe listen --forward-to http://localhost:3000/webhooks/stripe",
    "stripe:login": "C:\\Users\\gabri\\.stripe\\stripe.exe login",
    "stripe:trigger": "C:\\Users\\gabri\\.stripe\\stripe.exe trigger checkout.session.completed",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@scalar/express-api-reference": "^0.9.11",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "mongoose": "^8.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^3.11.174",
    "pizzip": "^3.2.0",
    "resend": "^6.12.3",
    "stripe": "^22.2.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pdf-parse": "^1.1.5",
    "@types/pizzip": "^3.0.5",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "concurrently": "^10.0.3",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
