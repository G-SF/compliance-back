# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_strong_random_secret_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_strong_secret_at_least_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# ─── MongoDB ──────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/backend_api

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Claude AI ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
CLAUDE_MAX_TOKENS=4096

# ─── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ─── Email (Resend) ────────────────────────────────────────────
# Obtenha a API key em https://resend.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxx
SMTP_FROM=Contracta <onboarding@resend.dev>

# ─── Frontend ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
